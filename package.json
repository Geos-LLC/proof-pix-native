{
  "name": "proof-pix-native",
  "version": "1.4.8",
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "postinstall": "patch-package",
    "build": "eas build --platform all",
    "build:ios": "eas build --platform ios",
    "build:android": "eas build --platform android",
    "build:ios:preview": "eas build --platform ios --profile preview",
    "build:ios:production": "eas build --platform ios --profile production",
    "build:android:preview": "eas build --platform android --profile preview",
    "build:android:production": "eas build --platform android --profile production",
    "submit:ios": "eas submit --platform ios --profile production",
    "submit:android": "eas submit --platform android --profile production",
    "update": "eas update --branch production --message \"Update app\"",
    "update:preview": "eas update --branch preview --message \"Preview update\"",
    "update:production": "eas update --branch production --message \"Production update\"",
    "publish": "eas update --branch production --message \"Publish update\""
  },
  "dependencies": {
