APP_NAME=ProofPix
VERSION=1.3.1

# Proxy URL (deployed Vercel function)
EXPO_PUBLIC_PROXY_URL=https://proof-pix-proxy.vercel.app

# Watermark URL
EXPO_PUBLIC_WATERMARK_URL=https://geos-ai.com/

# Google OAuth Configuration (Client IDs are public)
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your-web-client-id.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=your-ios-client-id.apps.googleusercontent.com

# Dropbox OAuth Configuration
EXPO_PUBLIC_DROPBOX_APP_KEY=your-dropbox-app-key

# EmailJS Configuration
EXPO_PUBLIC_EMAILJS_SERVICE_ID=your-emailjs-service-id
EXPO_PUBLIC_EMAILJS_TEMPLATE_ID=your-emailjs-template-id
EXPO_PUBLIC_EMAILJS_PUBLIC_KEY=your-emailjs-public-key

# App Store Links
EXPO_PUBLIC_IOS_APP_STORE_URL=https://apps.apple.com/app/id-your-app-id
EXPO_PUBLIC_ANDROID_PLAY_STORE_URL=https://play.google.com/store/apps/details?id=com.proofpix.app
